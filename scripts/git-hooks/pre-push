#!/bin/sh
# cofounder-relay pre-push hook.
# On every push to main, broadcast a standardized UPDATE notice to the relay's
# updates channel so partners' AIs know to pull + reinstall + verify. This is the
# mechanical guarantee behind "always announce updates" -- it fires automatically,
# nobody has to remember. Non-blocking: if the announce fails (offline, no config),
# the push still succeeds.
#
# Installed by install.ps1 via `git config core.hooksPath scripts/git-hooks`.
# Git for Windows runs hooks through its bundled sh, so POSIX sh is correct here.

repo=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0

while read -r local_ref local_sha remote_ref remote_sha; do
    case "$remote_ref" in
        refs/heads/main|*/main)
            # nothing being pushed (deletion) -> skip
            [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
            subj=$(git log -1 --format=%s "$local_sha" 2>/dev/null)
            [ -z "$subj" ] && subj="new changes on main"
            python "$repo/scripts/relay.py" announce "$subj" >/dev/null 2>&1 || true
            ;;
    esac
done

exit 0
